# ─── Project Configuration ───────────────────────────────────────────────────
# Copy this file to .env and edit the values for your project.
# The PROJECT_NAME is used for Docker container/volume names.
# The DOMAIN must end in .orb.local for OrbStack automatic DNS resolution.

PROJECT_NAME=myproject
DOMAIN=myproject.orb.local

# ─── WordPress Admin ──────────────────────────────────────────────────────────
# Leave WP_ADMIN_PASSWORD empty to have WP-CLI generate a random one (shown in setup output).

WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=
WP_ADMIN_EMAIL=admin@example.com

# ─── Stack Configuration ──────────────────────────────────────────────────────
PHP_VERSION=8.4
DB_PORT=3306
DB_NAME=myproject
DB_USER=myproject
DB_PASSWORD=secret
DB_PREFIX=wp_

# ─── Container Paths (stable, don't change between projects) ─────────────────
# DEV_USER is the container's internal username — avoids conflict with the shell's $USERNAME.
DEV_USER=dev
WORKSPACE_ROOT=/workspace
DEVCONTAINER_DIR=/workspace/.devcontainer

# ─── Caddy Configuration ──────────────────────────────────────────────────────
WEB_ROOT=www/web
PHP_FPM_SOCKET=127.0.0.1:9000
HTTP_PORT=80
HTTPS_PORT=443
ACCESS_LOG=www/logs/caddy-access.log
